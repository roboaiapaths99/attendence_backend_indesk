# OfficeFlow Backend — Environment Configuration
# Copy this file to .env and fill in your values

# ─── MongoDB ────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appname>
DATABASE_NAME=attendance_db

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ─── Environment ─────────────────────────────────────────────────────────────
# Set to 'production' to disable /docs and /redoc
APP_ENV=development
LOG_LEVEL=INFO

# ─── CORS (Production) ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for dev only.
# Example: https://admin.yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=*

# ─── Office Geofencing ───────────────────────────────────────────────────────
OFFICE_LAT=28.4145947
OFFICE_LONG=77.354079
GEOFENCE_RADIUS_METERS=30

# ─── WiFi Verification ───────────────────────────────────────────────────────
OFFICE_WIFI_BSSID=
# Leave OFFICE_WIFI_SSID empty to skip SSID check
OFFICE_WIFI_SSID=
MIN_WIFI_SIGNAL_STRENGTH=-80

# ─── Security Mode ───────────────────────────────────────────────────────────
# Set to 'false' for local testing outside office/wifi
STRICT_MODE=true

# ─── Google Sheets Sync (Optional) ───────────────────────────────────────────
GOOGLE_SHEET_ID=
SERVICE_ACCOUNT_JSON_PATH=./service-account.json
